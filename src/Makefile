UNAME_S := $(shell uname -s 2>/dev/null)
UNAME_M := $(shell uname -m 2>/dev/null)

ifeq ($(UNAME_S),Linux)
	SHIP_DIR=Linux_ReleaseG/ship/
	ifeq ($(UNAME_M),x86_64)
		PLATFORM_ARCH=x86_64-linux
	else ifeq ($(UNAME_M),aarch64)
		PLATFORM_ARCH=aarch64-linux
	else ifeq ($(UNAME_M),arm64)
		PLATFORM_ARCH=aarch64-linux
	else
		PLATFORM_ARCH=$(UNAME_M)-linux
	endif
else
	SHIP_DIR=WinNT_ReleaseG/ship/
	# Detect Windows architecture
	ifeq ($(PROCESSOR_ARCHITECTURE),AMD64)
		PLATFORM_ARCH=x86_64-windows
	else ifeq ($(PROCESSOR_ARCHITECTURE),ARM64)
		PLATFORM_ARCH=aarch64-windows
	else ifeq ($(UNAME_M),x86_64)
		PLATFORM_ARCH=x86_64-windows
	else ifeq ($(UNAME_M),aarch64)
		PLATFORM_ARCH=aarch64-windows
	else ifeq ($(UNAME_M),arm64)
		PLATFORM_ARCH=aarch64-windows
	else
		# Default to x86_64 if unable to detect
		PLATFORM_ARCH=x86_64-windows
	endif
endif

GHC_VERSION := $(shell ghc --numeric-version)
D=dist-newstyle/build/$(PLATFORM_ARCH)/ghc-$(GHC_VERSION)
Q=$D/qaic-0.0/build/qaic/qaic$(EXEC_EXT)
F=file2hs/$D/file2hs-0.0/build/file2hs/file2hs$(EXEC_EXT)

GEN_FILES=Language/SO/Stub.hs\
          Language/SO/Skel.hs\
          Language/SO/CStub.hs\
          Language/SO/Env.hs\
          Language/SO/Allocator.hs\
          Language/SO/Wstring.hs\
          Language/SO/Slim.hs

# Default target
all: $Q

$F:file2hs/file2hs.hs $C
	cd file2hs && cabal configure && cabal build
	touch $@

# Pattern rule to generate .hs files from .c files
%.hs:%.c $F
	cat $< | ./$F $(subst /,.,$*) source > $@

$Q:Compiler/Version.hs $(GEN_FILES) $F $C
	cabal configure && cabal build
	touch $@
	mkdir -p $(SHIP_DIR)
	cp $Q $(SHIP_DIR)

file2hs_clean:
	cd file2hs && cabal clean

clean_cabal:
	cabal clean

clean:clean_cabal file2hs_clean

BUILD_COPIES+= $Q
BUILD_COPIES+= $V/UsersGuide.html
BUILD_COPIES+= doc/UsersGuide.txt
BUILD_COPIES+= $V/IdlReference.html
BUILD_COPIES+= doc/IdlReference.txt
BUILD_COPIES+= $V/ReleaseNotes.html
BUILD_COPIES+= ReleaseNotes.txt
BUILD_COPIES+= $(SHIP_DIR)/ ;

VERSION := $(shell grep "gitcommit" Compiler/Version.hs | wc -l)
GIT_COMMIT_LEN := 0
ifeq ($(VERSION),0)
	GIT_COMMIT = \"$(shell git log -n 1 | head -n 1 | cut -d' ' -f 2)\"
	GIT_COMMIT_LEN = $(shell git log -n 1 | head -n 1 | cut -d' ' -f 2 | wc -m)
endif

GHC := $(shell grep "ghcVersion" Compiler/Version.hs | wc -l)
IS_GHC_INSTALLED = 0
ifeq ($(GHC),0)
	GHC_FULL_VERSION = \"$(shell ghc --version)\"
	ifneq (,$(findstring version,$(GHC_FULL_VERSION)))
		IS_GHC_INSTALLED = 1
	endif
endif

CABAL := $(shell grep "cabalVersion" Compiler/Version.hs | wc -l)
IS_CABAL_INSTALLED = 0
ifeq ($(CABAL),0)
	CABAL_VERSION = \"$(shell cabal --version)\"
	ifneq (,$(findstring version,$(CABAL_VERSION)))
		IS_CABAL_INSTALLED = 1
	endif
endif

PLATFORM := $(shell grep "platform" Compiler/Version.hs | wc -l)
OS_TYPE = ""
ifeq ($(PLATFORM),0)
	ifeq ($(OS),Windows_NT)
		OS_TYPE = \"windows\"
	else
		OS_TYPE = \"$(shell cat /etc/os-release | egrep "PRETTY_NAME|VERSION_ID" | cut -d = -f 2 | head -1)\"
	endif
endif

Compiler/Version.hs: Makefile
	echo >> Compiler/Version.hs
ifeq ($(GIT_COMMIT_LEN),41)
	echo "--Autogenerated function : The last gitcommit ID of qaicSrc that was used to build QAIC binary" >> Compiler/Version.hs
	echo "gitcommit :: String" >> Compiler/Version.hs
	echo "gitcommit = $(GIT_COMMIT)" >> Compiler/Version.hs
	echo >> Compiler/Version.hs
endif
ifeq ($(IS_GHC_INSTALLED), 1)
	echo "--Autogenerated function : The ghc version used to build the QAIC binary" >> Compiler/Version.hs
	echo "ghcVersion :: String" >> Compiler/Version.hs
	echo "ghcVersion = $(GHC_FULL_VERSION)" >> Compiler/Version.hs
	echo >> Compiler/Version.hs
endif
ifeq ($(IS_CABAL_INSTALLED), 1)
	echo "--Autogenerated function : The cabal version used to build the QAIC binary" >> Compiler/Version.hs
	echo "cabalVersion :: String" >> Compiler/Version.hs
	echo "cabalVersion = $(CABAL_VERSION)" >> Compiler/Version.hs
endif
ifeq ($(PLATFORM),0)
	echo "--Autogenerated function : The platform on which the QAIC binary was built" >> Compiler/Version.hs
	echo "platform :: String" >> Compiler/Version.hs
	echo "platform = $(OS_TYPE)" >> Compiler/Version.hs
	echo >> Compiler/Version.hs
endif

clean_qaic_relics:
	$(call rm_rf, $(GEN_FILES) $V)

clean:clean_qaic_relics

update:
	p4 revert $O/...
	p4 delete $O/*
	$(call mkdir_p,$O)
	cp $V/ship/* $O/
	p4 revert $O/*
	p4 sync -f $O/*
	p4 edit $O/*
	cp $V/ship/* $O/
	p4 revert -a $O/*

SMARKEXT_banner_SMARKDIR += doc
SMARKEXT_banner_SMARKDIR += $(MAKE_D_DOCS_COMMON_INCDIR)

BUILD_SMARKDOCS      = doc/IdlReference.txt \
                       doc/UsersGuide.txt \
                       ReleaseNotes.txt
